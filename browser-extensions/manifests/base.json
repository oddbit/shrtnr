{
  "manifest_version": 3,
  "name": "shrtnr — Self-hosted URL shortener",
  "short_name": "shrtnr",
  "version": "0.1.0",
  "description": "Shorten the current tab into your own self-hosted shrtnr. One click. Free, open-source, runs on Cloudflare.",
  "author": "Oddbit",
  "homepage_url": "https://oddb.it/shrtnr-info",
  "action": {
    "default_title": "Shorten this page with shrtnr",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["activeTab", "storage", "clipboardWrite"],
  "optional_host_permissions": ["*://*/*"]
}
